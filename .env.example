# Database name
POSTGRES_DATABASE=tundra_market

# Database user
POSTGRES_USER=tundra_market

# Database password
POSTGRES_PASSWORD=tundra_market_password

# Database host in Docker
POSTGRES_HOST=postgres

# Database port
POSTGRES_PORT=5432

# Database URL for local Go run
DATABASE_URL=postgres://tundra_market:tundra_market_password@localhost:5432/tundra_market?sslmode=disable

# API server address
HTTP_ADDR=:8000

# Token signing secret
AUTH_TOKEN_SECRET=secret

# Token lifetime
AUTH_TOKEN_TTL=8760h
